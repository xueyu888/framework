{
  "@framework Module Template": {
    "prefix": "@framework",
    "description": "Insert keyword-first framework module template.",
    "body": [
      "# ${1:中文模块名}:${2:EnglishName}",
      "",
      "@framework",
      "",
      "## Goal",
      "",
      "goal ${3:GoalName} := ${4:本模块的目标是什么}",
      "",
      "## Base",
      "",
      "base ${5:BaseName} := ${6:一句定义或 Lx.My::Base.Name}",
      "",
