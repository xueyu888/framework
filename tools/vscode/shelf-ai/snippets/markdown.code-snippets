      "",
      "bd.out ${26:OutputName} := payload(${27:...}), cardinality(${28:...}), from(${29:cs.Name})",
      "",
      "### Parameter",
      "",
      "bd.param ${30:ParameterName} := domain(${31:...}), affects(${32:cp.form.Name / cp.sat.Name / cp.id.Name / cp.norm.Name / cs.Name / bd.in.Name / bd.out.Name})"
    ]
  },
  "base Statement": {
    "prefix": "base",
