{
  "name": "shelf-ai",
  "displayName": "Shelf AI",
  "description": "Shelf AI: canonical-first navigation for the Framework -> Config -> Code -> Evidence chain.",
  "version": "0.1.8",
  "publisher": "rdshr",
  "license": "SEE LICENSE IN LICENSE.txt",
  "repository": {
    "type": "git",
    "url": "https://github.com/xueyu888/shelf.git"
  },
  "bugs": {
    "url": "https://github.com/xueyu888/shelf/issues"
  },
  "homepage": "https://github.com/xueyu888/shelf/tree/main/tools/vscode/shelf-ai",
  "engines": {
    "vscode": "^1.85.0"
  },
  "files": [
    "CHANGELOG.md",
    "LICENSE.txt",
    "README.md",
    "extension.js",
    "tree_runtime_models.js",
    "tree_webview_bridge.js",
    "guarding.js",
    "evidence_tree.js",
    "framework_completion.js",
    "framework_navigation.js",
    "validation_runtime.js",
    "intent_gate.js",
    "media/**",
    "snippets/**"
  ],
  "categories": [
    "Linters",
    "Other"
  ],
  "scripts": {
    "build:webview": "node scripts/build_tree_webview.mjs",
    "check:webview-types": "tsc --pretty false --noEmit -p webview/tree/tsconfig.json",
    "test": "node test_guarding.js && node test_framework_navigation.js && node test_evidence_tree.js && node test_validation_runtime.js && node test_intent_gate.js && node test_snippets.js && node test_tree_runtime_models.js && node test_tree_webview_bridge.js",
    "vscode:prepublish": "npm run build:webview"
  },
  "devDependencies": {
    "@types/d3-selection": "^3.0.11",
    "@types/d3-zoom": "^3.0.8",
    "@types/dagre": "^0.7.52",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "dagre": "^0.8.5",
    "esbuild": "^0.25.9",
    "typescript": "^5.9.2"
  },
  "activationEvents": [
    "onStartupFinished",
    "onView:shelf.sidebarHome",
    "onCommand:shelf.insertFrameworkModuleTemplate",
    "onCommand:shelf.installGitHooks",
    "onCommand:shelf.startGovernedTask",
    "onCommand:shelf.showGovernedTaskSession",
    "onCommand:shelf.clearGovernedTaskSession",
    "onCommand:shelf.validateNow",
    "onCommand:shelf.codegenPreflight",
    "onCommand:shelf.publishFrameworkDraft",
    "onCommand:shelf.openFrameworkTree",
    "onCommand:shelf.refreshFrameworkTree",
    "onCommand:shelf.openEvidenceTree",
    "onCommand:shelf.refreshEvidenceTree"
  ],
  "main": "./extension.js",
  "contributes": {
    "snippets": [
      {
        "language": "markdown",
        "path": "./snippets/markdown.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "shelf.insertFrameworkModuleTemplate",
        "title": "Shelf: Insert Framework Module Template"
      },
      {
        "command": "shelf.validateNow",
        "title": "Shelf: Validate Canonical Now"
      },
      {
        "command": "shelf.codegenPreflight",
        "title": "Shelf: Run Codegen Preflight"
      },
      {
        "command": "shelf.publishFrameworkDraft",
        "title": "Shelf: Publish Current Framework Draft"
      },
      {
        "command": "shelf.installGitHooks",
        "title": "Shelf: Install Git Hooks"
      },
      {
        "command": "shelf.startGovernedTask",
        "title": "Shelf: Start Governed Task"
      },
      {
        "command": "shelf.showGovernedTaskSession",
        "title": "Shelf: Show Governed Task Session"
      },
      {
        "command": "shelf.clearGovernedTaskSession",
        "title": "Shelf: Clear Governed Task Session"
      },
      {
        "command": "shelf.showIssues",
        "title": "Shelf: Show Validation Issues"
      },
      {
        "command": "shelf.openFrameworkTree",
        "title": "Shelf: Open Framework Tree"
      },
      {
        "command": "shelf.refreshFrameworkTree",
        "title": "Shelf: Refresh Framework Tree"
      },
      {
        "command": "shelf.openEvidenceTree",
        "title": "Shelf: Open Evidence Tree"
      },
      {
        "command": "shelf.refreshEvidenceTree",
        "title": "Shelf: Refresh Evidence Tree"
      }
    ],
    "icons": {
      "shelf-logo": {
        "description": "Shelf AI Activity Bar icon",
        "default": {
          "fontPath": "media/shelf-ai-icons.woff2",
          "fontCharacter": "\\ea01"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "shelfSidebar",
          "title": "Shelf",
          "icon": "$(shelf-logo)"
        }
      ]
    },
    "views": {
      "shelfSidebar": [
        {
          "id": "shelf.sidebarHome",
          "name": "Shelf",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "shelf.startGovernedTask",
          "when": "view == shelf.sidebarHome",
          "group": "navigation@1"
        },
        {
          "command": "shelf.openFrameworkTree",
          "when": "view == shelf.sidebarHome",
          "group": "navigation@2"
        },
        {
          "command": "shelf.refreshFrameworkTree",
          "when": "view == shelf.sidebarHome",
          "group": "navigation@3"
        },
        {
          "command": "shelf.openEvidenceTree",
          "when": "view == shelf.sidebarHome",
          "group": "navigation@4"
        },
        {
          "command": "shelf.refreshEvidenceTree",
          "when": "view == shelf.sidebarHome",
          "group": "navigation@5"
        },
        {
          "command": "shelf.validateNow",
          "when": "view == shelf.sidebarHome",
          "group": "navigation@6"
        },
        {
          "command": "shelf.codegenPreflight",
          "when": "view == shelf.sidebarHome",
          "group": "navigation@7"
        },
        {
          "command": "shelf.publishFrameworkDraft",
          "when": "view == shelf.sidebarHome",
          "group": "navigation@8"
        },
        {
          "command": "shelf.installGitHooks",
          "when": "view == shelf.sidebarHome",
          "group": "navigation@9"
        }
      ]
    },
    "configuration": {
      "title": "Shelf",
      "properties": {
        "shelf.enableOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run canonical validation when a relevant file is saved."
        },
        "shelf.validationTriggerMode": {
          "type": "string",
          "enum": [
            "manual",
            "save",
            "all"
          ],
          "default": "all",
          "description": "Choose whether Shelf validates only on demand, only on save, or on all watched workspace events."
        },
        "shelf.notifyOnAutoFail": {
          "type": "boolean",
          "default": true,
          "description": "Show notification when auto validation detects canonical issues."
        },
        "shelf.guardMode": {
          "type": "string",
          "enum": [
            "normal",
            "strict"
          ],
          "default": "normal",
          "description": "Choose whether Shelf only reports generated-artifact edits or automatically restores them."
        },
        "shelf.autoMaterialize": {
          "type": "boolean",
          "default": true,
          "description": "Automatically run project materialization when framework markdown or project.toml changes."
        },
        "shelf.runMypyOnPythonChanges": {
          "type": "boolean",
          "default": true,
          "description": "Run mypy after relevant Python changes under src/, scripts/, or tests/."
        },
        "shelf.protectGeneratedFiles": {
          "type": "boolean",
          "default": true,
          "description": "Guard projects/*/generated/* from direct edits."
        },
        "shelf.promptInstallGitHooks": {
          "type": "boolean",
          "default": true,
          "description": "Prompt once per session to enable the repository .githooks path when missing."
        },
        "shelf.intentGateEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the governed-task intent gate. Guarded implementation saves require an active mapping-confirmed task session."
        },
        "shelf.intentGateEnforcementMode": {
          "type": "string",
          "enum": [
            "warn",
            "block"
          ],
          "default": "block",
          "description": "Choose whether guarded saves only warn or are blocked/reverted when no active governed-task session exists."
        },
        "shelf.intentGateRequireMappingEcho": {
          "type": "boolean",
          "default": true,
          "description": "Require an explicit QuickPick confirmation of canonical mappings before granting a governed-task session."
        },
        "shelf.intentGateRunChangeValidationBeforeGrant": {
          "type": "boolean",
          "default": true,
          "description": "Run `validate_canonical.py --check-changes` before granting a governed-task session."
        },
        "shelf.intentGateAutoOpenOutput": {
          "type": "boolean",
          "default": true,
          "description": "Auto-open the Shelf output channel after intent-to-framework mapping analysis."
        },
        "shelf.intentGateMinimumScore": {
          "type": "integer",
          "default": 4,
          "minimum": 1,
          "maximum": 20,
          "description": "Minimum mapping score threshold for intent-to-framework gate matching."
        },
        "shelf.intentGateMaxMatches": {
          "type": "integer",
          "default": 8,
          "minimum": 1,
          "maximum": 20,
          "description": "Maximum number of canonical mapping candidates retained in a governed-task session."
        },
        "shelf.intentGateSessionTtlMinutes": {
          "type": "integer",
          "default": 120,
          "minimum": 1,
          "maximum": 1440,
          "description": "Time-to-live for a governed-task session. Expired sessions are cleared and guarded saves are blocked again."
        },
        "shelf.intentGateGuardedPathPrefixes": {
          "type": "array",
          "default": [
            "*"
          ],
          "items": {
            "type": "string"
          },
          "description": "Workspace-relative path prefixes guarded by the intent gate on save. Use `*` to guard all workspace code paths."
        },
        "shelf.intentGateIgnoredPathPrefixes": {
          "type": "array",
          "default": [
            ".git/",
            ".github/",
            ".venv/",
            "node_modules/",
            "dist/",
            "build/",
            "out/",
            ".pytest_cache/",
            ".mypy_cache/",
            "__pycache__/"
          ],
          "items": {
            "type": "string"
          },
          "description": "Workspace-relative path prefixes excluded from intent-gate save interception."
        },
        "shelf.changeValidationCommand": {
          "type": "string",
          "default": "uv run python scripts/validate_canonical.py --check-changes",
          "description": "Command used for save-triggered validation."
        },
        "shelf.fullValidationCommand": {
          "type": "string",
          "default": "uv run python scripts/validate_canonical.py",
          "description": "Command used for manual full validation."
        },
        "shelf.materializeCommand": {
          "type": "string",
          "default": "uv run python scripts/materialize_project.py",
          "description": "Base command used for Shelf auto-materialization. Shelf appends --project-file arguments for affected project.toml files."
        },
        "shelf.typeCheckCommand": {
          "type": "string",
          "default": "uv run mypy",
          "description": "Command used when Shelf runs Python type checks after relevant source changes."
        },
        "shelf.frameworkTreeNodeHorizontalGap": {
          "type": "integer",
          "default": 8,
          "minimum": 0,
          "maximum": 40,
          "description": "Horizontal gap, in pixels, between framework tree nodes within the same level."
        },
        "shelf.frameworkTreeLevelVerticalGap": {
          "type": "integer",
          "default": 80,
          "minimum": 48,
          "maximum": 180,
          "description": "Vertical gap, in pixels, between framework tree levels."
        },
        "shelf.treeZoomMinScale": {
          "type": "number",
          "default": 0.68,
          "minimum": 0.2,
          "maximum": 3,
          "description": "Minimum zoom scale for Shelf tree webviews."
        },
        "shelf.treeZoomMaxScale": {
          "type": "number",
          "default": 1.55,
          "minimum": 0.2,
          "maximum": 5,
          "description": "Maximum zoom scale for Shelf tree webviews."
        },
        "shelf.treeWheelSensitivity": {
          "type": "number",
          "default": 1,
          "minimum": 0.25,
          "maximum": 3,
          "description": "Wheel zoom sensitivity multiplier for Shelf tree webviews."
        },
        "shelf.treeInspectorWidth": {
          "type": "integer",
          "default": 338,
          "minimum": 240,
          "maximum": 520,
          "description": "Preferred inspector panel width, in pixels, for Shelf tree webviews."
        },
        "shelf.treeInspectorRailWidth": {
          "type": "integer",
          "default": 42,
          "minimum": 32,
          "maximum": 72,
          "description": "Collapsed inspector rail width, in pixels, for Shelf tree webviews."
        },
        "shelf.validationCommandTimeoutMs": {
          "type": "integer",
          "default": 120000,
          "minimum": 1000,
          "maximum": 1800000,
          "description": "Timeout, in milliseconds, for Shelf validation and preflight commands."
        },
        "shelf.generatedEventSuppressionMs": {
          "type": "integer",
          "default": 2500,
          "minimum": 0,
          "maximum": 30000,
          "description": "Suppression window, in milliseconds, for generated file watcher events right after materialization."
        },
        "shelf.manualValidationRestartThresholdMs": {
          "type": "integer",
          "default": 15000,
          "minimum": 1000,
          "maximum": 300000,
          "description": "Elapsed time threshold, in milliseconds, before Shelf can restart a stale validation command on manual retrigger."
        },
        "shelf.validationDebounceMs": {
          "type": "integer",
          "default": 250,
          "minimum": 0,
          "maximum": 5000,
          "description": "Debounce delay, in milliseconds, before Shelf starts a queued validation run."
        }
      }
    }
  }
}
