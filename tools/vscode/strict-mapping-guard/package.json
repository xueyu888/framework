{
  "name": "strict-mapping-guard",
  "displayName": "Strict Mapping Guard",
  "description": "Run strict mapping validation on save and surface issues in Problems.",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:strictMapping.validateNow"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "strictMapping.validateNow",
        "title": "Strict Mapping: Validate Now"
      }
    ],
    "configuration": {
      "title": "Strict Mapping Guard",
      "properties": {
        "strictMappingGuard.enableOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run strict mapping validation when a relevant file is saved."
        },
        "strictMappingGuard.changeValidationCommand": {
          "type": "string",
          "default": "uv run python scripts/validate_strict_mapping.py --check-changes --json",
          "description": "Command used for save-triggered validation."
        },
        "strictMappingGuard.fullValidationCommand": {
          "type": "string",
          "default": "uv run python scripts/validate_strict_mapping.py --json",
          "description": "Command used for manual full validation."
        }
      }
    }
  }
}
